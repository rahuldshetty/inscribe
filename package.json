{
	"name": "inscribe",
	"private": false,
	"version": "0.0.1",
	"description": "A minimalist Static Site Generator (SSG) for blogs and documentation.",
	"type": "module",
	"bin": {
		"inscribe": "./cli/index.ts"
	},
	"files": [
		"cli",
		"template",
		"package.json",
		"README.md"
	],
	"engines": {
		"node": ">=20.0.0",
		"bun": ">=1.0.0"
	},
	"keywords": [
		"ssg",
		"static-site-generator",
		"blog",
		"documentation",
		"bun",
		"mdx",
		"preact"
	],
	"author": "rahuldshetty",
	"license": "MIT",
	"scripts": {
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"inscribe": "bun ./cli/index.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/bun": "^1.3.10",
		"@types/html-minifier-terser": "^7.0.2",
		"@types/node": "^24",
		"@types/nunjucks": "^3.2.6",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.3.0",
		"html-minifier-terser": "^7.2.0",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0"
	},
	"dependencies": {
		"@mdx-js/mdx": "^3.1.1",
		"@types/fs-extra": "^11.0.4",
		"clerc": "^1.3.1",
		"dompurify": "^3.3.2",
		"fs-extra": "^11.3.4",
		"jsdom": "^28.1.0",
		"marked": "^17.0.4",
		"nunjucks": "^3.2.4",
		"preact": "^10.28.4",
		"preact-render-to-string": "^6.6.6",
		"yaml": "^2.8.2",
		"zod": "^4.3.6"
	}
}
