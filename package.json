{
	"name": "inscribe",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"bin": {
		"inscribe": "./dist/index.js"
	},
	"files": [
		"dist/index.js"
	],
	"scripts": {
		"inscribe": "bun ./cli/index.ts",
		"cli:build": "bun run cli:build:win && bun run cli:build:linux && bun run cli:build:macos && bun run cli:build:js",
		"cli:build:win": "bun build ./cli/index.ts --compile --target bun-windows-x64 --outfile dist/inscribe-win.exe",
		"cli:build:linux": "bun build ./cli/index.ts --compile --target bun-linux-x64 --outfile dist/inscribe-linux",
		"cli:build:macos": "bun build ./cli/index.ts --compile --target bun-darwin-arm64 --outfile dist/inscribe-macos",
		"cli:build:js": "bun build ./cli/index.ts --outfile dist/index.js --target node",
		"prepublishOnly": "bun run cli:build:js",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"clerc": "^1.3.1"
	}
}