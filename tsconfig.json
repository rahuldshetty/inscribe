{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"sourceMap": true,
		"allowJs": true,
		"checkJs": true,
		"rewriteRelativeImportExtensions": true
	},
	"include": ["cli/**/*.ts", "template/**/*.ts", "dist/**/*.ts"]
}
